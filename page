<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Petr Pělucha Photography – Návrh homepage</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#B8974A;
  --gold-light:#D4B472;
  --dark:#1A1714;
  --mid:#3A3530;
  --warm:#F5F1EB;
  --soft:#EDE8E0;
  --text:#2A2520;
  --muted:#7A7268;
  --white:#FDFCFA;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--text);line-height:1.6}
h1,h2,h3,.serif{font-family:'Cormorant Garamond',serif}
.page{max-width:1100px;margin:0 auto;padding:0 2rem}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;padding:1.25rem 2rem;border-bottom:0.5px solid rgba(184,151,74,0.25);background:var(--white);position:sticky;top:0;z-index:200}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;letter-spacing:0.08em;color:var(--dark);text-decoration:none;flex-shrink:0}
.nav-logo span{color:var(--gold)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:0.78rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color 0.2s}
.nav-links a:hover{color:var(--gold)}
.nav-cta{font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;background:var(--dark);color:var(--warm);padding:0.55rem 1.3rem;border-radius:2px;text-decoration:none;transition:background 0.2s;flex-shrink:0}
.nav-cta:hover{background:var(--gold)}
.nav-hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;background:none;border:none;cursor:pointer;padding:4px;width:36px;height:36px}
.nav-hamburger span{display:block;height:1.5px;background:var(--dark);transition:all 0.28s ease;transform-origin:center}
.nav-hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
.nav-hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.nav-hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}
.nav-mobile-menu{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:var(--white);z-index:190;flex-direction:column;align-items:center;justify-content:center;gap:2.5rem}
.nav-mobile-menu.open{display:flex}
.nav-mobile-menu a{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;color:var(--dark);text-decoration:none;letter-spacing:0.04em;transition:color 0.2s}
.nav-mobile-menu a:hover{color:var(--gold)}
.nav-mobile-menu .mobile-cta{font-family:'DM Sans',sans-serif;font-size:0.78rem;letter-spacing:0.14em;text-transform:uppercase;background:var(--dark);color:var(--warm);padding:0.75rem 2.5rem;border-radius:2px;margin-top:1rem}
.nav-mobile-menu .mobile-cta:hover{background:var(--gold);color:var(--dark)}
.nav-mobile-close{position:absolute;top:1.5rem;right:2rem;background:none;border:none;cursor:pointer;font-size:1.5rem;color:var(--muted);line-height:1}

/* HERO */
.hero{display:grid;grid-template-columns:1fr 1fr;min-height:92vh;position:relative;overflow:hidden}
.hero-left{background:#1c1915;display:flex;flex-direction:column;justify-content:flex-end;padding:4rem 3rem;position:relative;cursor:pointer}
.hero-left::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(26,23,20,0.88) 0%,rgba(26,23,20,0.25) 60%,transparent 100%)}
.hero-right{background:#ede8e0;display:flex;flex-direction:column;justify-content:flex-end;padding:4rem 3rem;position:relative;cursor:pointer}
.hero-right::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(237,232,224,0.92) 0%,rgba(237,232,224,0.15) 60%,transparent 100%)}
.hero-photo-dark{background:repeating-linear-gradient(45deg,#1e1b17 0px,#1e1b17 2px,#231f1b 2px,#231f1b 14px)}
.hero-photo-light{background:repeating-linear-gradient(45deg,#e2dcd3 0px,#e2dcd3 2px,#ede8e0 2px,#ede8e0 14px)}
.hero-placeholder{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;text-align:center;width:80%}
.hero-placeholder.light-ph{color:rgba(42,37,32,0.2)}
.hero-placeholder.dark-ph{color:rgba(255,255,255,0.15)}
.hero-tag{font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);margin-bottom:0.75rem;position:relative;z-index:2}
.hero-title-dark{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;line-height:1.12;color:#fdfcfa;position:relative;z-index:2;margin-bottom:1rem}
.hero-title-dark em{font-style:italic;color:var(--gold-light)}
.hero-title-light{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;line-height:1.12;color:var(--dark);position:relative;z-index:2;margin-bottom:1rem}
.hero-title-light em{font-style:italic;color:var(--gold)}
.hero-desc-dark{font-size:0.82rem;line-height:1.7;color:rgba(255,255,255,0.6);position:relative;z-index:2;margin-bottom:1.75rem;max-width:24ch}
.hero-desc-light{font-size:0.82rem;line-height:1.7;color:var(--muted);position:relative;z-index:2;margin-bottom:1.75rem;max-width:24ch}
.hero-btn{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;padding:0.8rem 1.6rem;border:1px solid var(--gold);color:var(--gold);background:transparent;cursor:pointer;position:relative;z-index:2;transition:all 0.25s;text-decoration:none;width:fit-content;font-family:'DM Sans',sans-serif}
.hero-btn:hover{background:var(--gold);color:var(--dark)}
.hero-btn-light{border-color:var(--dark);color:var(--dark)}
.hero-btn-light:hover{background:var(--dark);color:var(--warm)}
.hero-divider{position:absolute;left:50%;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent 0%,rgba(184,151,74,0.55) 25%,rgba(184,151,74,0.55) 75%,transparent 100%);z-index:10}
.hero-badge{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);z-index:20;background:var(--white);border:1px solid rgba(184,151,74,0.45);border-radius:50%;width:84px;height:84px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;box-shadow:0 0 0 8px rgba(253,252,250,0.6)}
.hero-badge .hb-name{font-family:'Cormorant Garamond',serif;font-size:0.62rem;letter-spacing:0.1em;color:var(--dark);font-weight:600;line-height:1.4}
.hero-badge .hb-years{font-size:0.58rem;letter-spacing:0.1em;color:var(--gold);text-transform:uppercase;margin-top:0.15rem}

/* TRUST BAR */
.trust-bar{background:var(--dark);padding:1.1rem 2rem;display:flex;align-items:center;justify-content:center;gap:3rem;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:0.65rem}
.trust-num{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:600;color:var(--gold-light);line-height:1}
.trust-label{font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.45)}
.trust-dot{width:3px;height:3px;border-radius:50%;background:rgba(184,151,74,0.35)}

/* SECTIONS */
.section{padding:6rem 0}
.section-tag{font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:0.75rem}
.section-title{font-family:'Cormorant Garamond',serif;font-size:2.6rem;font-weight:300;line-height:1.2;margin-bottom:1rem}
.section-title em{font-style:italic}

/* BIZNIS */
.biz-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.biz-visual{background:repeating-linear-gradient(45deg,#1a1714 0px,#1a1714 2px,#201d19 2px,#201d19 14px);aspect-ratio:4/5;border-radius:2px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.biz-visual::after{content:'';position:absolute;bottom:0;left:0;right:0;height:38%;background:linear-gradient(to top,rgba(26,23,20,0.72),transparent);pointer-events:none}
.biz-quote{position:absolute;bottom:1.75rem;left:1.75rem;font-family:'Cormorant Garamond',serif;font-size:1rem;font-style:italic;color:rgba(255,255,255,0.65);z-index:2;line-height:1.5}
.photo-label{font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.18)}
.photo-label-light{font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(42,37,32,0.2)}
.arg-list{display:flex;flex-direction:column;gap:1.5rem;margin:2rem 0}
.arg-item{display:flex;gap:1rem;align-items:flex-start}
.arg-num{font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--gold);font-weight:600;min-width:1.75rem;padding-top:0.05rem}
.arg-text h4{font-size:0.8rem;letter-spacing:0.04em;font-weight:500;margin-bottom:0.2rem;color:var(--dark)}
.arg-text p{font-size:0.8rem;color:var(--muted);line-height:1.65}
.price-row{display:flex;gap:1rem;margin:2rem 0}
.price-card{flex:1;border:0.5px solid rgba(184,151,74,0.3);padding:1.35rem 1.1rem;border-radius:2px;position:relative}
.price-card.featured{border-color:var(--gold);background:rgba(184,151,74,0.04)}
.price-badge{position:absolute;top:-0.55rem;left:1rem;font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;background:var(--gold);color:#fff;padding:0.18rem 0.65rem;border-radius:1px}
.price-name{font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.3rem}
.price-amount{font-family:'Cormorant Garamond',serif;font-size:1.65rem;font-weight:600;color:var(--dark);line-height:1.2}
.price-desc{font-size:0.72rem;color:var(--muted);margin-top:0.25rem;line-height:1.5}
.btn-primary{display:inline-flex;align-items:center;gap:0.6rem;font-size:0.72rem;letter-spacing:0.13em;text-transform:uppercase;padding:0.9rem 2.1rem;background:var(--dark);color:var(--warm);border:none;cursor:pointer;border-radius:2px;transition:background 0.2s;text-decoration:none;font-family:'DM Sans',sans-serif;font-weight:400}
.btn-primary:hover{background:var(--gold)}

/* WEDDING */
.wedding-section{background:var(--dark);color:var(--warm)}
.wedding-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.wedding-visual{background:repeating-linear-gradient(-45deg,#26221e 0px,#26221e 2px,#2e2923 2px,#2e2923 14px);aspect-ratio:4/5;border-radius:2px;display:flex;align-items:center;justify-content:center}
.wedding-section .section-tag{color:var(--gold-light)}
.wedding-section .section-title{color:var(--warm)}
.wedding-section .arg-num{color:var(--gold-light)}
.wedding-section .arg-text h4{color:var(--warm)}
.wedding-section .arg-text p{color:rgba(253,252,250,0.52)}
.wedding-section .price-card{border-color:rgba(212,180,114,0.22)}
.wedding-section .price-card.featured{border-color:var(--gold-light);background:rgba(212,180,114,0.06)}
.wedding-section .price-amount{color:var(--warm)}
.wedding-section .price-name{color:rgba(253,252,250,0.42)}
.wedding-section .price-desc{color:rgba(253,252,250,0.42)}
.wedding-section .price-badge{background:var(--gold-light);color:var(--dark)}
.btn-wedding{background:transparent;color:var(--gold-light);border:1px solid var(--gold-light);display:inline-flex;align-items:center;gap:0.6rem;font-size:0.72rem;letter-spacing:0.13em;text-transform:uppercase;padding:0.9rem 2.1rem;cursor:pointer;border-radius:2px;transition:all 0.2s;text-decoration:none;font-family:'DM Sans',sans-serif;font-weight:400}
.btn-wedding:hover{background:var(--gold-light);color:var(--dark)}
.gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0.85rem;margin-top:3.5rem}
.gallery-thumb{aspect-ratio:3/4;background:repeating-linear-gradient(45deg,#26221e 0,#26221e 2px,#2e2923 2px,#2e2923 10px);border-radius:2px}

/* ABOUT */
.about-section{background:var(--warm);padding:6rem 0}
.about-grid{display:grid;grid-template-columns:5fr 7fr;gap:5rem;align-items:center}
.about-img{aspect-ratio:3/4;background:repeating-linear-gradient(45deg,#c5bdb0 0,#c5bdb0 2px,#cdc5b7 2px,#cdc5b7 10px);border-radius:2px;display:flex;align-items:center;justify-content:center}
.about-quote{font-family:'Cormorant Garamond',serif;font-size:1.55rem;font-weight:300;font-style:italic;line-height:1.5;color:var(--dark);margin-bottom:1.5rem;padding-left:1.5rem;border-left:2px solid var(--gold)}
.about-body{font-size:0.82rem;color:var(--muted);line-height:1.85}
.about-sig{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-style:italic;color:var(--gold);margin-top:1.5rem}

/* REVIEWS */
.reviews-section{background:var(--white);padding:5.5rem 0}
.reviews-head{text-align:center;margin-bottom:3rem}
.reviews-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}
.review-card{border:0.5px solid rgba(184,151,74,0.2);padding:2.25rem 2rem;border-radius:2px;position:relative;background:var(--white)}
.review-card::before{content:'\201C';font-family:'Cormorant Garamond',serif;font-size:4.5rem;color:var(--gold);opacity:0.25;position:absolute;top:0.6rem;left:1.6rem;line-height:1}
.review-text{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-style:italic;color:var(--text);line-height:1.7;margin-bottom:1.25rem;padding-top:1.5rem}
.review-author{font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted)}
.review-chip{display:inline-block;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.22rem 0.65rem;margin-top:0.5rem;border-radius:1px}
.chip-biz{background:rgba(184,151,74,0.1);color:var(--gold)}
.chip-wed{background:rgba(26,23,20,0.07);color:var(--mid)}

/* KURZ – kompaktní banner */
.kurz-section{background:var(--soft);padding:4rem 0}
.kurz-inner{display:grid;grid-template-columns:1fr auto;gap:3rem;align-items:center;border:0.5px solid rgba(184,151,74,0.3);border-radius:2px;padding:2.5rem 3rem;background:var(--white)}
.kurz-kicker{font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:0.5rem}
.kurz-title{font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:300;line-height:1.2;color:var(--dark);margin-bottom:0.75rem}
.kurz-title em{font-style:italic}
.kurz-desc{font-size:0.8rem;color:var(--muted);line-height:1.75;max-width:52ch}
.kurz-meta{display:flex;gap:1.5rem;margin-top:1rem;flex-wrap:wrap}
.kurz-pill{font-size:0.68rem;letter-spacing:0.08em;color:var(--mid);background:var(--soft);padding:0.3rem 0.75rem;border-radius:1px;border:0.5px solid rgba(184,151,74,0.25)}
.kurz-cta{flex-shrink:0;text-align:right}
.kurz-cta .btn-primary{white-space:nowrap}
.kurz-cta .kurz-note{font-size:0.68rem;color:var(--muted);margin-top:0.6rem;text-align:center}

/* BLOG – 3 kartičky */
.blog-section{background:var(--white);padding:5rem 0}
.blog-head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:2.5rem}
.blog-head-left .section-tag{margin-bottom:0.25rem}
.blog-head-left .section-title{margin-bottom:0;font-size:2rem}
.blog-all{font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);text-decoration:none;transition:color 0.2s}
.blog-all:hover{color:var(--dark)}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.blog-card{border:0.5px solid rgba(184,151,74,0.18);border-radius:2px;overflow:hidden;text-decoration:none;display:flex;flex-direction:column;transition:border-color 0.2s}
.blog-card:hover{border-color:var(--gold)}
.blog-thumb{aspect-ratio:16/10;background:repeating-linear-gradient(45deg,#e0dbd2 0,#e0dbd2 2px,#e8e2d8 2px,#e8e2d8 10px);display:flex;align-items:center;justify-content:center}
.blog-thumb-dark{background:repeating-linear-gradient(45deg,#1e1b17 0,#1e1b17 2px,#261f1a 2px,#261f1a 10px)}
.blog-body{padding:1.25rem 1.25rem 1.5rem;display:flex;flex-direction:column;flex:1}
.blog-cat{font-size:0.6rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin-bottom:0.4rem}
.blog-title{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:400;color:var(--dark);line-height:1.4;margin-bottom:auto}
.blog-date{font-size:0.68rem;color:var(--muted);margin-top:1rem;letter-spacing:0.04em}

/* FORM */
.form-section{background:var(--dark);padding:6.5rem 0}
.form-intro{text-align:center;margin-bottom:3rem}
.form-intro .section-title{color:var(--warm)}
.form-intro .section-tag{color:var(--gold-light)}
.form-intro p{font-size:0.82rem;color:rgba(253,252,250,0.5);max-width:44ch;margin:0 auto;line-height:1.75}
.form-box{background:rgba(255,255,255,0.035);border:0.5px solid rgba(184,151,74,0.22);padding:3rem 3.5rem;border-radius:2px;max-width:700px;margin:0 auto}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.form-full{grid-column:1/-1}
.field-label{display:block;font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(253,252,250,0.45);margin-bottom:0.5rem}
.field-input{width:100%;background:rgba(255,255,255,0.05);border:0.5px solid rgba(184,151,74,0.22);border-radius:2px;padding:0.8rem 1rem;font-family:'DM Sans',sans-serif;font-size:0.85rem;color:var(--warm);outline:none;transition:border-color 0.2s;-webkit-appearance:none;appearance:none}
.field-input::placeholder{color:rgba(253,252,250,0.22)}
.field-input:focus{border-color:var(--gold)}
select.field-input option{background:#1a1714;color:var(--warm)}
textarea.field-input{resize:vertical;min-height:110px}
.dynamic-field{display:none}
.dynamic-field.visible{display:block}
.form-submit{width:100%;padding:1.05rem;background:var(--gold);border:none;color:var(--dark);font-family:'DM Sans',sans-serif;font-size:0.75rem;letter-spacing:0.17em;text-transform:uppercase;cursor:pointer;border-radius:2px;margin-top:0.5rem;transition:background 0.2s;font-weight:500}
.form-submit:hover{background:var(--gold-light)}
.form-note{text-align:center;font-size:0.68rem;color:rgba(253,252,250,0.28);margin-top:1rem;letter-spacing:0.05em}

/* FOOTER */
footer{background:var(--dark);border-top:0.5px solid rgba(184,151,74,0.18);padding:3rem 0}
.footer-inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.25rem}
.footer-logo{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:600;color:var(--warm);letter-spacing:0.08em;text-decoration:none}
.footer-logo span{color:var(--gold)}
.footer-contact{font-size:0.74rem;color:rgba(253,252,250,0.38);text-align:center;line-height:1.9}
.footer-contact a{color:var(--gold-light);text-decoration:none}
.footer-contact a:hover{color:var(--warm)}
.footer-social{display:flex;gap:1.25rem}
.footer-social a{font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(253,252,250,0.38);text-decoration:none;transition:color 0.2s}
.footer-social a:hover{color:var(--gold-light)}

/* PREVIEW BANNER */
.preview-banner{background:var(--gold);padding:0.6rem 1.5rem;text-align:center;font-size:0.72rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--dark);font-weight:500}

/* RESPONSIVE */
@media(max-width:900px){
  .nav-links,.nav-cta{display:none}
  .nav-hamburger{display:flex}
  .hero{grid-template-columns:1fr;min-height:auto}
  .hero-left,.hero-right{padding:3rem 2rem;min-height:60vw}
  .hero-divider,.hero-badge{display:none}
  .hero-title-dark,.hero-title-light{font-size:2.4rem}
  .biz-grid,.wedding-grid,.about-grid{grid-template-columns:1fr;gap:2.5rem}
  .biz-visual,.wedding-visual,.about-img{aspect-ratio:16/9}
  .reviews-grid{grid-template-columns:1fr}
  .form-grid{grid-template-columns:1fr}
  .form-full{grid-column:1}
  .form-box{padding:2rem 1.5rem}
  .trust-bar{gap:1.5rem}
  .gallery-grid{grid-template-columns:repeat(3,1fr)}
  .kurz-inner{grid-template-columns:1fr;gap:1.5rem}
  .kurz-cta{text-align:left}
  .blog-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:560px){
  .hero-left,.hero-right{padding:2.5rem 1.5rem}
  .hero-title-dark,.hero-title-light{font-size:2rem}
  .section{padding:4rem 0}
