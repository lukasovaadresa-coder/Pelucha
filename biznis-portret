<script>
// NAV
function toggleMobileMenu(){var m=document.getElementById('mobileMenu'),b=document.getElementById('hamburgerBtn');if(m.classList.contains('open')){closeMobileMenu()}else{m.classList.add('open');b.classList.add('open');document.body.style.overflow='hidden'}}
function closeMobileMenu(){document.getElementById('mobileMenu').classList.remove('open');document.getElementById('hamburgerBtn').classList.remove('open');document.body.style.overflow=''}

// SMOOTH SCROLL pro kotvy s offset navigace
document.querySelectorAll('a[href^="#"]').forEach(function(link) {
  link.addEventListener('click', function(e) {
    var target = document.querySelector(this.getAttribute('href'));
    if (!target) return;
    e.preventDefault();
    var navHeight = document.querySelector('.nav') ? document.querySelector('.nav').offsetHeight : 72;
    var top = target.getBoundingClientRect().top + window.pageYOffset - navHeight;
    window.scrollTo({top: top, behavior: 'smooth'});
  });
});
var galleryItems=[
  {caption:'Karlos Vémola',portrait:true},
  {caption:'JUDr. Roman Horáček, Ph.D., MBA',portrait:true},
  {caption:'Anna Gruberová',portrait:true},
  {caption:'Pavel Maršík, Palasino',portrait:false},
  {caption:'JUDr. Dominik Brůha, AKBR',portrait:true},
  {caption:'Veronika Benáčová, Allwyn',portrait:true},
  {caption:'Filip Sailer',portrait:true}
];
var currentIdx=0;
function openLightbox(idx){currentIdx=idx;updateLightbox();document.getElementById('lightbox').classList.add('open');document.body.style.overflow='hidden'}
function closeLightbox(){document.getElementById('lightbox').classList.remove('open');document.body.style.overflow=''}
function navLightbox(dir){currentIdx=(currentIdx+dir+galleryItems.length)%galleryItems.length;updateLightbox()}
function updateLightbox(){
  var item=galleryItems[currentIdx];
  var ph=document.getElementById('lightboxPh');
  ph.className='lightbox-ph'+(item.portrait?'':' landscape');
  document.getElementById('lightboxPhTxt').textContent='[ '+item.caption+' ]';
  document.getElementById('lightboxCaption').textContent=item.caption;
  document.getElementById('lightboxCounter').textContent=(currentIdx+1)+' / '+galleryItems.length;
}
document.getElementById('lightbox').addEventListener('click',function(e){if(e.target===this)closeLightbox()});
document.addEventListener('keydown',function(e){
  if(!document.getElementById('lightbox').classList.contains('open'))return;
  if(e.key==='ArrowLeft')navLightbox(-1);
  if(e.key==='ArrowRight')navLightbox(1);
  if(e.key==='Escape')closeLightbox();
});

// MODAL
function openModal(pkg,price){
  document.getElementById('modalPkgInfo').textContent='Balíček: '+pkg+' · '+price;
  document.getElementById('poptavkaModal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){document.getElementById('poptavkaModal').classList.remove('open');document.body.style.overflow=''}
document.getElementById('poptavkaModal').addEventListener('click',function(e){if(e.target===this)closeModal()});
function submitModal(){
  var n=document.getElementById('m-name').value.trim(),c=document.getElementById('m-contact').value.trim();
  if(!n||!c){alert('Vyplňte prosím jméno a kontakt.');return}
  closeModal();alert('Díky, '+n+'! Ozvu se vám do 24 hodin.')
}
</script>
